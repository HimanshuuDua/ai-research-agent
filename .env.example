# Google Gemini — https://aistudio.google.com/apikey (must start with AIza)
GOOGLE_API_KEY=AIzaSy-your-google-api-key
# Or multiple keys in one variable:
# GOOGLE_API_KEY=key-from-account-1,key-from-account-2
# Or preferred explicit list:
# GOOGLE_API_KEYS=key-from-account-1,key-from-account-2

# Optional model overrides
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# SerpAPI (web search) — https://serpapi.com/
SERPAPI_API_KEY=your-serpapi-key

# Supabase — persistent conversation storage (optional; falls back to local SQLite)
# 1. Create a project at https://supabase.com
# 2. Run supabase_schema.sql in Supabase → SQL Editor
# 3. Settings → API: copy the Project URL and the service_role key
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key

# Default recipients (server-side fallback only — never shown in the public UI)
RESEND_TO_EMAIL=you@example.com

# =============================================================================
# EMAIL — choose ONE provider
# =============================================================================

# RECOMMENDED for Vercel production: Brevo HTTP API (Gmail SMTP often fails on serverless)
# 1. Sign up free at https://www.brevo.com/
# 2. Verify your sender email in Brevo → Senders
# 3. Create API key in SMTP & API → API Keys
# EMAIL_PROVIDER=brevo
# BREVO_API_KEY=xkeysib-your-brevo-key
# Or comma-separated in one variable:
# BREVO_API_KEY=key-one,key-two
# BREVO_API_KEYS=key-one,key-two
# BREVO_FROM_EMAIL=you@gmail.com
# BREVO_FROM_NAME=AI Research Agent

# LOCAL / non-Vercel: Gmail SMTP (supports multiple accounts for rotation)
# 1. Enable 2-Step Verification on your Google account
# 2. Create App Password: https://myaccount.google.com/apppasswords
# 3. Single account:
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-google-app-password
SMTP_FROM=AI Research Agent <you@gmail.com>
# 4. Multiple Gmail accounts (comma-separated, same order):
# SMTP_USER=account1@gmail.com,account2@gmail.com
# SMTP_PASSWORD=app-password-1,app-password-2
# SMTP_FROM=AI Agent <account1@gmail.com>,AI Agent <account2@gmail.com>
# Or explicit lists:
# SMTP_USERS=account1@gmail.com,account2@gmail.com
# SMTP_PASSWORDS=app-password-1,app-password-2
# SMTP_FROMS=AI Agent <account1@gmail.com>,AI Agent <account2@gmail.com>

# ALTERNATIVE: Resend — test sender only emails your Resend account address
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_your-resend-key
# RESEND_FROM_EMAIL=onboarding@resend.dev
# RESEND_ACCOUNT_EMAIL=you@gmail.com

# Resend production (requires verified domain at resend.com/domains):
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_your-resend-key
# RESEND_FROM_EMAIL=AI Research Agent <notify@yourdomain.com>
