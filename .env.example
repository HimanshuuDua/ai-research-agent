# Google Gemini — https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key

# Optional model overrides
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# SerpAPI (web search) — https://serpapi.com/
SERPAPI_API_KEY=your-serpapi-key

# Resend (email) — https://resend.com/  [permanent free: 3,000 emails/month]
RESEND_API_KEY=re_your-resend-key
RESEND_FROM_EMAIL=onboarding@resend.dev
# One or more recipients (comma-separated). With onboarding@resend.dev you can only email your Resend account address.
RESEND_TO_EMAIL=you@example.com
