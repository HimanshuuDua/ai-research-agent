# Google Gemini — https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key

# Optional model overrides
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# SerpAPI (web search) — https://serpapi.com/
SERPAPI_API_KEY=your-serpapi-key

# Resend (email) — https://resend.com/
RESEND_API_KEY=re_your-resend-key

# --- TEST MODE (default) — only YOUR Resend account email can receive ---
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_TO_EMAIL=you@example.com
# Optional but recommended: the email you used to sign up at resend.com
# RESEND_ACCOUNT_EMAIL=you@example.com

# --- PRODUCTION MODE — send to anyone after domain verification ---
# 1. Verify your domain at https://resend.com/domains
# 2. Uncomment and set:
# RESEND_FROM_EMAIL=AI Research Agent <notify@yourdomain.com>
# RESEND_TO_EMAIL=you@example.com, teammate@company.com, client@business.com
# RESEND_ACCOUNT_EMAIL=
